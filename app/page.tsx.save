'use client';

import { useState, useEffect } from 'react';
import { supabase } from '../lib/supabase';

export default function Badirty() {
  const [user, setUser] = useState<any>(null);
  const [view, setView] = useState<'login' | 'signup'>('login');
  const [email, setEmail] = useState('');
  const [password, setPassword] = useState('');
  const [loading, setLoading] = useState(false);

  useEffect(() => {
    supabase.auth.getSession().then(({ data }) => setUser(data.session?.user || null));
  }, []);

  const signInWithProvider = async (provider: 'google' | 'apple') => {
    setLoading(true);
    await supabase.auth.signInWithOAuth({
      provider,
      options: { redirectTo: window.location.origin }
    });
    setLoading(false);
  };

  const handleEmailAuth = async () => {
    setLoading(true);
    if (view === 'login') {
      const { error } = await supabase.auth.signInWithPassword({ email, password });
      if (error) alert(error.message);
    } else {
      const { error } = await supabase.auth.signUp({ email, password });
      if (error) alert(error.message);
      else alert("Compte créé ! Vérifie ton email.");
    }
    setLoading(false);
  };

  return (
    <div className="min-h-screen bg-gradient-to-br from-zinc-950 to-black text-white flex items-center justify-center p-6">
      <div className="w-full max-w-md">
        <div className="text-center mb-12">
          <div className="inline-flex items-center gap-3 mb-6">
            <div className="w-12 h-12 bg-gradient-to-br from-pink-500 via-purple-500 to-violet-500 rounded-2xl flex items-center justify-center text-4xl">💎</div>
            <h1 className="text-6xl font-bold tracking-tighter neon-pink">badirty</h1>
          </div>
          <p className="text-zinc-400 text-xl">L’enchère intime. Anonyme. Addictif.</p>
        </div>

        <div className="bg-zinc-900/70 border border-zinc-800 rounded-3xl p-8 shadow-2xl">
          <div className="space-y-4">
            <button 
              onClick={() => signInWithProvider('google')}
              disabled={loading}
              className="w-full h-14 bg-white text-black rounded-2xl flex items-center justify-center gap-3 font-semibold hover:bg-zinc-100 transition">
              <img src="https://www.google.com/images/branding/googlelogo/1x/googlelogo_color_272x92dp.png" className="h-5" alt="Google" />
              Continuer avec Google
            </button>

            <button 
              onClick={() => signInWithProvider('apple')}
              disabled={loading}
              className="w-full h-14 bg-white text-black rounded-2xl flex items-center justify-center gap-3 font-semibold hover:bg-zinc-100 transition">
              <span className="text-2xl"></span>
              Continuer avec Apple
            </button>

            <div className="relative my-6">
              <div className="absolute inset-0 flex items-center"><div className="w-full border-t border-zinc-700"></div></div>
              <div className="relative text-center text-xs text-zinc-500 bg-zinc-900 px-4">OU</div>
            </div>

            <input
              type="email"
              placeholder="E-mail"
              value={email}
              onChange={(e) => setEmail(e.target.value)}
              className="w-full bg-zinc-800 border border-zinc-700 rounded-2xl px-5 py-4 outline-none focus:border-pink-500"
            />

            <input
              type="password"
              placeholder="Mot de passe"
              value={password}
              onChange={(e) => setPassword(e.target.value)}
              className="w-full bg-zinc-800 border border-zinc-700 rounded-2xl px-5 py-4 outline-none focus:border-pink-500"
            />

            <button 
              onClick={handleEmailAuth}
              disabled={loading}
              className="w-full h-14 bg-pink-600 rounded-2xl font-semibold text-lg hover:bg-pink-700 transition">
              {view === 'login' ? "Se connecter" : "Créer un compte"}
            </button>

            <button 
              onClick={() => setView(view === 'login' ? 'signup' : 'login')}
              className="w-full text-zinc-400 text-sm">
              {view === 'login' ? "Pas de compte ? S'inscrire" : "Déjà un compte ? Se connecter"}
            </button>
          </div>
        </div>

        <p className="text-center text-xs text-zinc-500 mt-8">En continuant, tu acceptes nos Conditions et Politique de confidentialité.</p>
      </div>
    </div>
  );
}
